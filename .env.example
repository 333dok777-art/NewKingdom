DATABASE_URL=postgresql://postgres:password@localhost:5432/newkingdom
RESEND_API_KEY=re_replace_me
EMAIL_FROM="NewKingdom <noreply@your-domain.example>"
APP_ORIGIN=http://localhost:5173
# Set this only when the Vite frontend runs separately from the API (for example,
# local Vite against Railway). Leave it unset when Express serves the built app.
VITE_API_BASE_URL=
API_PORT=3001
VERIFICATION_CODE_PEPPER=replace-with-a-long-random-secret
NODE_ENV=development
